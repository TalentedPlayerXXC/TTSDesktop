{
  "name": "huisheng",
  "version": "1.0.0",
  "description": "让文字会说话，让声音有灵魂",
  "main": "main.js",
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "start": "electron .",
    "preview": "vite build && electron .",
    "pack:mac": "vite build && electron-builder --mac --dir && codesign --force --deep --sign - release/mac-arm64/绘声.app && electron-builder --mac --prepackaged release/mac-arm64/绘声.app && cp 使用说明.md user-guide.md 修复.command release/",
    "pack:win": "vite build && electron-builder --win --x64",
    "pack:linux": "vite build && electron-builder --linux",
    "export:characters": "node scripts/export-characters.js"
  },
  "dependencies": {
    "@ant-design/icons": "6.x",
    "antd": "^6.4.3",
    "axios": "^1.16.1",
    "mongoose": "^9.7.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-h5-audio-player": "^3.10.2",
    "react-router": "^7.15.1",
    "tone": "^15.5.27",
    "wavesurfer.js": "^7.12.10"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "vite": "^6.0.0"
  },
  "build": {
    "appId": "com.tts.desktop",
    "productName": "绘声",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "mongo-worker.js",
      "db.js",
      "db.example.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "src/data/characters.json",
        "to": "characters.json"
      },
      {
        "from": "tts_serve_mlx",
        "to": "tts_serve_mlx"
      },
      {
        "from": "characters",
        "to": "characters"
      }
    ],
    "asar": true,
    "asarUnpack": [
      "preload.js",
      "mongo-worker.js",
      "db.js"
    ],
    "mac": {
      "icon": "build/icon.png",
      "target": "dmg",
      "category": "public.app-category.utilities"
    },
    "win": {
      "icon": "build/icon.png",
      "target": "nsis"
    },
    "linux": {
      "icon": "build/icon.png",
      "target": "AppImage"
    }
  }
}
